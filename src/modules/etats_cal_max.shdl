module etats_cal_max(rst, clk, cal, adCouranteInfAd2 : INITAD, INITMAX, MAJMAX, FINI)
   Dinit = /cal
   Dinitmax = INITAD * cal
   Dmajmax = INITMAX * cal + MAJMAX * adCouranteInfAd2 * cal
   Dfini = MAJMAX * /adCouranteInfAd2 * cal + FINI * cal
   
   INITAD := Dinit on clk set when rst 
   INITMAX := Dinitmax on clk reset when rst
   MAJMAX := Dmajmax on clk reset when rst
   FINI := Dfini on clk reset when rst
end module